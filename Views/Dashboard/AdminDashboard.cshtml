@model RestaurantManagement.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    /* ═══════════════════ ADMIN DASHBOARD ═══════════════════ */

    .dash-welcome {
        background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
        border-radius: 24px;
        padding: 32px 36px;
        color: #fff;
        margin-bottom: 28px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(15, 12, 41, 0.35);
    }

    .dash-welcome::before {
        content: '';
        position: absolute;
        top: -60%;
        right: -20%;
        width: 400px;
        height: 400px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(108, 99, 255, 0.25), transparent 70%);
    }

    .dash-welcome::after {
        content: '';
        position: absolute;
        bottom: -40%;
        left: 10%;
        width: 250px;
        height: 250px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(0, 210, 255, 0.15), transparent 70%);
    }

    .dash-welcome h2 {
        font-size: 1.85rem;
        font-weight: 700;
        margin: 0 0 6px;
        position: relative;
        z-index: 1;
    }

    .dash-welcome p {
        margin: 0;
        opacity: 0.7;
        font-size: 0.95rem;
        position: relative;
        z-index: 1;
    }

    /* ── Metric Cards ── */
    .metric-card {
        border-radius: 20px;
        padding: 24px;
        color: #fff;
        position: relative;
        overflow: hidden;
        min-height: 150px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .metric-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 18px 40px rgba(0,0,0,0.18);
    }

    .metric-card .metric-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: rgba(255,255,255,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        backdrop-filter: blur(6px);
    }

    .metric-card .metric-value {
        font-size: 2rem;
        font-weight: 800;
        line-height: 1;
        margin-top: 12px;
    }

    .metric-card .metric-label {
        font-size: 0.85rem;
        opacity: 0.85;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin-top: 4px;
    }

    .metric-card .metric-badge {
        position: absolute;
        top: 16px;
        right: 16px;
        background: rgba(255,255,255,0.2);
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.72rem;
        font-weight: 600;
        backdrop-filter: blur(6px);
    }

    .mc-violet  { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); box-shadow: 0 12px 30px rgba(102, 126, 234, 0.35); }
    .mc-coral   { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); box-shadow: 0 12px 30px rgba(245, 87, 108, 0.3); }
    .mc-cyan    { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); box-shadow: 0 12px 30px rgba(79, 172, 254, 0.3); }
    .mc-emerald { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); box-shadow: 0 12px 30px rgba(67, 233, 123, 0.3); }
    .mc-amber   { background: linear-gradient(135deg, #f6d365 0%, #fda085 100%); box-shadow: 0 12px 30px rgba(253, 160, 133, 0.3); }
    .mc-navy    { background: linear-gradient(135deg, #0f0c29 0%, #302b63 100%); box-shadow: 0 12px 30px rgba(48, 43, 99, 0.35); }

    /* ── Revenue Overview ── */
    .revenue-card {
        background: #fff;
        border-radius: 20px;
        padding: 28px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.06);
        border: 1px solid rgba(0,0,0,0.04);
    }

    .revenue-card h5 {
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 20px;
    }

    .rev-item {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 0;
        border-bottom: 1px solid #f0f0f5;
    }

    .rev-item:last-child {
        border-bottom: none;
    }

    .rev-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .rev-icon.today-icon { background: rgba(79, 172, 254, 0.12); color: #4facfe; }
    .rev-icon.month-icon { background: rgba(102, 126, 234, 0.12); color: #667eea; }
    .rev-icon.week-icon  { background: rgba(67, 233, 123, 0.12); color: #38c172; }

    .rev-info .rev-label {
        font-size: 0.8rem;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .rev-info .rev-amount {
        font-size: 1.4rem;
        font-weight: 800;
        color: #1a1a2e;
    }

    /* ── Recent Orders ── */
    .orders-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.06);
        border: 1px solid rgba(0,0,0,0.04);
        overflow: hidden;
    }

    .orders-card-header {
        padding: 20px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #f0f0f5;
    }

    .orders-card-header h5 {
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
    }

    .order-row {
        display: flex;
        align-items: center;
        padding: 14px 24px;
        border-bottom: 1px solid #fafafa;
        transition: background 0.2s;
    }

    .order-row:hover {
        background: #f8f9ff;
    }

    .order-row:last-child {
        border-bottom: none;
    }

    .order-id {
        font-weight: 700;
        color: #667eea;
        width: 70px;
        flex-shrink: 0;
    }

    .order-table-cell {
        width: 70px;
        flex-shrink: 0;
    }

    .order-table-num {
        background: #f0f0f5;
        padding: 4px 10px;
        border-radius: 8px;
        font-size: 0.8rem;
        font-weight: 600;
        color: #444;
        display: inline-block;
    }

    .order-item-name {
        flex: 1;
        color: #555;
        font-size: 0.9rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .order-status-pill {
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .pill-ready    { background: rgba(67, 233, 123, 0.12); color: #22c55e; }
    .pill-pending  { background: rgba(251, 191, 36, 0.15); color: #d97706; }
    .pill-cooking  { background: rgba(79, 172, 254, 0.12); color: #3b82f6; }
    .pill-default  { background: rgba(0,0,0,0.06);         color: #888; }

    .order-time {
        font-size: 0.82rem;
        color: #aaa;
        width: 60px;
        text-align: right;
        flex-shrink: 0;
    }

    /* ── Quick Actions ── */
    .quick-action-link {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 16px 20px;
        border-radius: 16px;
        font-weight: 700;
        font-size: 0.92rem;
        text-decoration: none;
        color: #fff;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .quick-action-link:hover {
        transform: translateY(-3px);
        color: #fff;
    }

    .qa-violet { background: linear-gradient(135deg, #667eea, #764ba2); box-shadow: 0 8px 20px rgba(102, 126, 234, 0.35); }
    .qa-coral  { background: linear-gradient(135deg, #f093fb, #f5576c); box-shadow: 0 8px 20px rgba(245, 87, 108, 0.3); }
    .qa-cyan   { background: linear-gradient(135deg, #4facfe, #00f2fe); box-shadow: 0 8px 20px rgba(79, 172, 254, 0.3); }

    .qa-violet:hover { box-shadow: 0 14px 30px rgba(102, 126, 234, 0.45); }
    .qa-coral:hover  { box-shadow: 0 14px 30px rgba(245, 87, 108, 0.4); }
    .qa-cyan:hover   { box-shadow: 0 14px 30px rgba(79, 172, 254, 0.4); }

    /* ── Live Indicator ── */
    .live-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #43e97b;
        margin-right: 6px;
        animation: livePulse 2s ease-in-out infinite;
    }

    @@keyframes livePulse {
        0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(67, 233, 123, 0.5); }
        50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(67, 233, 123, 0); }
    }
</style>

<!-- Welcome Banner -->
<div class="dash-welcome">
    <h2><i class="bi bi-grid-1x2-fill me-2"></i>Welcome Back, Admin</h2>
    <p>@DateTime.Now.ToString("dddd, MMMM dd, yyyy") &mdash; <span class="live-dot"></span> System Online</p>
</div>

<!-- Metric Cards Row -->
<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-4">
        <div class="metric-card mc-violet">
            <span class="metric-badge"><i class="bi bi-arrow-up"></i> +30%</span>
            <div class="metric-icon"><i class="bi bi-receipt-cutoff"></i></div>
            <div>
                <div class="metric-value">@Model.TotalOrders</div>
                <div class="metric-label">Total Orders</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="metric-card mc-coral">
            <span class="metric-badge"><i class="bi bi-hourglass-split"></i> Live</span>
            <div class="metric-icon"><i class="bi bi-clock-history"></i></div>
            <div>
                <div class="metric-value">@Model.PendingOrders</div>
                <div class="metric-label">Pending Orders</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="metric-card mc-cyan">
            <span class="metric-badge"><i class="bi bi-arrow-up"></i> +12%</span>
            <div class="metric-icon"><i class="bi bi-currency-dollar"></i></div>
            <div>
                <div class="metric-value">$@Model.TodayRevenue.ToString("N0")</div>
                <div class="metric-label">Today's Revenue</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="metric-card mc-emerald">
            <div class="metric-icon"><i class="bi bi-people-fill"></i></div>
            <div>
                <div class="metric-value">@Model.TotalEmployees</div>
                <div class="metric-label">Employees</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="metric-card mc-amber">
            <div class="metric-icon"><i class="bi bi-menu-button-wide-fill"></i></div>
            <div>
                <div class="metric-value">@Model.TotalMenuItems</div>
                <div class="metric-label">Menu Items</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="metric-card mc-navy">
            <div class="metric-icon"><i class="bi bi-grid-3x3-gap-fill"></i></div>
            <div>
                <div class="metric-value">@Model.AvailableTables / @(Model.AvailableTables + Model.OccupiedTables)</div>
                <div class="metric-label">Tables Available</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Revenue Overview -->
    <div class="col-lg-5">
        <div class="revenue-card h-100">
            <h5><i class="bi bi-bar-chart-line-fill me-2 text-primary"></i>Revenue Overview</h5>
            <div class="rev-item">
                <div class="rev-icon today-icon"><i class="bi bi-calendar-day"></i></div>
                <div class="rev-info">
                    <div class="rev-label">Today</div>
                    <div class="rev-amount">$@Model.TodayRevenue.ToString("N2")</div>
                </div>
            </div>
            <div class="rev-item">
                <div class="rev-icon week-icon"><i class="bi bi-calendar-week"></i></div>
                <div class="rev-info">
                    <div class="rev-label">This Week (est.)</div>
                    <div class="rev-amount">$@((Model.MonthlyRevenue / 4).ToString("N2"))</div>
                </div>
            </div>
            <div class="rev-item">
                <div class="rev-icon month-icon"><i class="bi bi-calendar-month"></i></div>
                <div class="rev-info">
                    <div class="rev-label">This Month</div>
                    <div class="rev-amount">$@Model.MonthlyRevenue.ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Orders -->
    <div class="col-lg-7">
        <div class="orders-card h-100">
            <div class="orders-card-header">
                <h5><i class="bi bi-clock-history me-2"></i>Recent Orders</h5>
                <a href="@Url.Action("Index", "Order")" class="btn btn-sm btn-outline-primary rounded-pill px-3">View All</a>
            </div>
            <div>
                @foreach (var order in Model.RecentOrders.Take(6))
                {
                    <div class="order-row">
                        <span class="order-id">#@order.Id</span>
                        <span class="order-table-cell">
                            <span class="order-table-num">T-@order.Table?.TableNumber</span>
                        </span>
                        <span class="order-item-name">@order.OrderItems.FirstOrDefault()?.MenuItem?.Name</span>
                        <span>
                            @if (order.Status == RestaurantManagement.Models.OrderStatus.Ready)
                            {
                                <span class="order-status-pill pill-ready">Ready</span>
                            }
                            else if (order.Status == RestaurantManagement.Models.OrderStatus.Pending)
                            {
                                <span class="order-status-pill pill-pending">Pending</span>
                            }
                            else if (order.Status == RestaurantManagement.Models.OrderStatus.Preparing)
                            {
                                <span class="order-status-pill pill-cooking">Cooking</span>
                            }
                            else
                            {
                                <span class="order-status-pill pill-default">@order.Status</span>
                            }
                        </span>
                        <span class="order-time">@order.OrderDate.ToString("HH:mm")</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-4">
    <div class="col-md-4">
        <a href="@Url.Action("Create", "Order")" class="quick-action-link qa-violet">
            <i class="bi bi-plus-circle-fill"></i> New Order
        </a>
    </div>
    <div class="col-md-4">
        <a href="@Url.Action("Index", "Menu")" class="quick-action-link qa-coral">
            <i class="bi bi-menu-button-wide"></i> Manage Menu
        </a>
    </div>
    <div class="col-md-4">
        <a href="@Url.Action("Daily", "Report")" class="quick-action-link qa-cyan">
            <i class="bi bi-graph-up-arrow"></i> View Reports
        </a>
    </div>
</div>
