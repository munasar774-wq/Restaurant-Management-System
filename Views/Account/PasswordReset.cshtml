@{
    ViewData["Title"] = "Password Reset";
    Layout = "_Layout";
}

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <i class="bi bi-key"></i>
            <h2>Password Reset</h2>
        </div>

        <div class="alert alert-success">
            <h5><i class="bi bi-check-circle"></i> Password Reset Complete!</h5>
        </div>

        @if (ViewBag.Results != null)
        {
            <ul class="list-unstyled mb-4">
                @foreach (var result in ViewBag.Results)
                {
                    <li class="mb-2">@result</li>
                }
            </ul>
        }

        <div class="alert alert-warning">
            <strong>New Password:</strong> @ViewBag.NewPassword
        </div>

        <p class="text-muted small">
            ⚠️ Please delete the ResetAdminPassword method from AccountController.cs after use for security!
        </p>

        <a href="@Url.Action("Login", "Account")" class="btn btn-primary w-100 mt-3">
            <i class="bi bi-box-arrow-in-right"></i> Go to Login
        </a>
    </div>
</div>
