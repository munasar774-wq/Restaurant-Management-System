@model RestaurantManagement.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Account Settings";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 mt-4">
            <div class="card-header bg-white border-0 pt-4 pb-0 text-center">
                <div class="mb-3">
                    <div class="d-inline-flex align-items-center justify-content-center text-white rounded-circle shadow-sm" style="background: linear-gradient(135deg, #6366f1, #8b5cf6); width: 80px; height: 80px; font-size: 2rem;">
                        <i class="bi bi-shield-lock"></i>
                    </div>
                </div>
                <h4 class="mb-0 fw-bold">Security Settings</h4>
                <p class="text-muted">Update your account password</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Settings" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-key text-muted"></i></span>
                            <input asp-for="CurrentPassword" class="form-control form-control-lg border-start-0 ps-0" placeholder="Enter current password" />
                        </div>
                        <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-lock text-muted"></i></span>
                            <input asp-for="NewPassword" class="form-control form-control-lg border-start-0 ps-0" placeholder="Enter new password" />
                        </div>
                        <div class="form-text">Must be at least 6 characters long and contain uppercase, lowercase, numbers, and symbols.</div>
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-lock-fill text-muted"></i></span>
                            <input asp-for="ConfirmPassword" class="form-control form-control-lg border-start-0 ps-0" placeholder="Confirm new password" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-lg text-white rounded-3 fw-bold shadow-sm" style="background: linear-gradient(135deg, #6366f1, #8b5cf6);">Update Password</button>
                        <a href="@Url.Action("Index", "Dashboard")" class="btn btn-light btn-lg rounded-3 text-muted">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
