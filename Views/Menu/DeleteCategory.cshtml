@model RestaurantManagement.Models.Category
@{
    ViewData["Title"] = "Delete Category";
}

<div class="page-header">
    <h1><i class="bi bi-trash"></i> Delete Category</h1>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle"></i>
                    Are you sure you want to delete this category?
                </div>
                
                @if (Model.MenuItems.Any())
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-info-circle"></i>
                        This category has <strong>@Model.MenuItems.Count</strong> menu items. 
                        You must remove them first before deleting.
                    </div>
                }
                
                <dl class="row">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>
                    
                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">@Model.Description</dd>
                    
                    <dt class="col-sm-4">Menu Items</dt>
                    <dd class="col-sm-8">@Model.MenuItems.Count</dd>
                </dl>
                
                <form asp-action="DeleteCategory" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger" @(Model.MenuItems.Any() ? "disabled" : "")>
                            <i class="bi bi-trash"></i> Delete
                        </button>
                        <a href="@Url.Action("Categories")" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
