@model RestaurantManagement.ViewModels.AssignRoleViewModel
@{
    ViewData["Title"] = "Assign Role";
}

<div class="page-header">
    <h1><i class="bi bi-person-gear"></i> Assign Role</h1>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="mb-4">Assign role to: <strong>@Model.UserName</strong></h5>
                <p>Current Role: <span class="badge bg-primary">@Model.CurrentRole</span></p>
                
                <form asp-action="AssignRole" method="post">
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="UserName" />
                    
                    <div class="mb-4">
                        <label asp-for="SelectedRole" class="form-label">New Role</label>
                        <select asp-for="SelectedRole" class="form-select">
                            @foreach (var role in Model.AvailableRoles)
                            {
                                <option value="@role" selected="@(role == Model.CurrentRole)">@role</option>
                            }
                        </select>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> Assign Role
                        </button>
                        <a href="@Url.Action("Index")" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
