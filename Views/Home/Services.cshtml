@{
    ViewData["Title"] = "Services";
    Layout = "_PublicLayout";
}

<div class="container section-padding">
    <div class="section-title">
        <h2>Our Services</h2>
    </div>
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="service-card">
                <div class="service-icon">
                    <i class="bi bi-cart4"></i>
                </div>
                <h4>Online Ordering</h4>
                <p>Conveniently order your favorite dishes online and have them ready for pickup or delivery.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="service-card">
                <div class="service-icon">
                    <i class="bi bi-calendar-check"></i>
                </div>
                <h4>Table Reservation</h4>
                <p>Reserve a table for your next visit. We accommodate groups of all sizes.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="service-card">
                <div class="service-icon">
                    <i class="bi bi-truck"></i>
                </div>
                <h4>Home Delivery</h4>
                <p>Enjoy our delicious food in the comfort of your own home with our fast delivery service.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="service-card">
                <div class="service-icon">
                    <i class="bi bi-cup-straw"></i>
                </div>
                <h4>Catering</h4>
                <p>Let us cater your next event! We offer customizable menus to suit your needs.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="service-card">
                <div class="service-icon">
                    <i class="bi bi-music-note-beamed"></i>
                </div>
                <h4>Private Events</h4>
                <p>Host your private parties or corporate events at Nexora. We offer private dining areas.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="service-card">
                <div class="service-icon">
                    <i class="bi bi-gift"></i>
                </div>
                <h4>Gift Cards</h4>
                <p>Give the gift of great food! Our gift cards are perfect for any occasion.</p>
            </div>
        </div>
    </div>
</div>
