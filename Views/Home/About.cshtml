@{
    ViewData["Title"] = "About Us";
    Layout = "_PublicLayout";
}

<div class="container section-padding">
    <div class="row">
        <div class="col-lg-8 offset-lg-2 text-center">
            <div class="section-title">
                <h2>About Nexora</h2>
            </div>
            <p class="lead mb-5">
                NEXORA RESTAURANT is a premier dining destination known for its exceptional cuisine and vibrant atmosphere.
            </p>
        </div>
    </div>
    <div class="row align-items-center mb-5">
        <div class="col-md-6 order-md-2">
            <div class="about-img">
                 <img src="https://images.unsplash.com/photo-1514933651103-005eec06c04b?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80" alt="Restaurant Interior">
            </div>
        </div>
        <div class="col-md-6 order-md-1">
             <h3>Our Story</h3>
             <p>Founded with a passion for excellence, Nexora Restaurant has quickly become a favorite among locals and visitors alike. We pride ourselves on our attention to detail and our commitment to customer satisfaction.</p>
             <p>Whether you're joining us for a casual lunch, a romantic dinner, or a special celebration, we strive to make every visit memorable.</p>
        </div>
    </div>
</div>
