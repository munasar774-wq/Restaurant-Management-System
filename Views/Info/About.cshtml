@{
    ViewData["Title"] = "About Us";
}

<div class="page-header">
    <h1><i class="bi bi-info-circle"></i> About Us</h1>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <div class="text-center mb-4">
                    <i class="bi bi-shop text-primary" style="font-size: 5rem;"></i>
                    <h2 class="mt-3">Restaurant Management System</h2>
                </div>
                
                <p class="lead text-center">
                    Welcome to our Restaurant Management System - a complete solution for managing 
                    your restaurant operations efficiently.
                </p>
                
                <hr class="my-4" />
                
                <h4><i class="bi bi-bullseye text-primary"></i> Our Mission</h4>
                <p>
                    To provide restaurants with a powerful, user-friendly system that streamlines 
                    daily operations, from order management to employee tracking and financial reporting.
                </p>
                
                <h4 class="mt-4"><i class="bi bi-eye text-primary"></i> Our Vision</h4>
                <p>
                    To become the leading restaurant management solution, helping businesses of all sizes 
                    optimize their operations and deliver exceptional customer experiences.
                </p>
                
                <h4 class="mt-4"><i class="bi bi-star text-primary"></i> Why Choose Us?</h4>
                <ul>
                    <li>Easy-to-use interface for all staff levels</li>
                    <li>Real-time order tracking and status updates</li>
                    <li>Comprehensive reporting and analytics</li>
                    <li>Role-based access control for security</li>
                    <li>Fast and responsive design</li>
                </ul>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-telephone"></i> Get In Touch
            </div>
            <div class="card-body">
                <p><i class="bi bi-telephone-fill text-primary"></i> <strong>Phone:</strong> 615015937</p>
                <p><i class="bi bi-envelope-fill text-primary"></i> <strong>Email:</strong> munasar774@gmail.com</p>
                <a href="@Url.Action("Contact", "Info")" class="btn btn-primary w-100">
                    <i class="bi bi-chat-dots"></i> Contact Us
                </a>
            </div>
        </div>
        
        <div class="card mt-3">
            <div class="card-header">
                <i class="bi bi-gear"></i> Our Services
            </div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    <li><i class="bi bi-check-circle text-success"></i> Order Management</li>
                    <li><i class="bi bi-check-circle text-success"></i> Table Management</li>
                    <li><i class="bi bi-check-circle text-success"></i> Employee Management</li>
                    <li><i class="bi bi-check-circle text-success"></i> Payment Processing</li>
                    <li><i class="bi bi-check-circle text-success"></i> Reports & Analytics</li>
                </ul>
                <a href="@Url.Action("Services", "Info")" class="btn btn-outline-primary w-100 mt-3">
                    <i class="bi bi-arrow-right"></i> View All Services
                </a>
            </div>
        </div>
    </div>
</div>
