    <div class="card-body text-center py-5">
        <h3>Ready to Get Started?</h3>
        <p class="mb-4">Contact us today to learn more about our restaurant management solutions</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a href="tel:615015937" class="btn btn-light btn-lg">
                <i class="bi bi-telephone"></i> Call: 615015937
            </a>
            <a href="mailto:munasar774@gmail.com" class="btn btn-outline-light btn-lg">
                <i class="bi bi-envelope"></i> Email Us
            </a>
        </div>
    </div>
</div>
