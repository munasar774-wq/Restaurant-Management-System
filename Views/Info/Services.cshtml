@{
    ViewData["Title"] = "Our Services";
}

<div class="page-header">
    <h1><i class="bi bi-gear"></i> Our Services</h1>
</div>

<p class="lead text-center mb-5">
    Comprehensive restaurant management solutions to streamline your operations
</p>

<div class="row">
    <!-- Order Management -->
    <div class="col-lg-4 col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <div class="stat-card blue mx-auto mb-3" style="width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-receipt" style="font-size: 2rem;"></i>
                </div>
                <h4>Order Management</h4>
                <p class="text-muted">
                    Create, track, and manage orders with real-time status updates. 
                    Support for multiple items, special instructions, and order history.
                </p>
                <ul class="list-unstyled text-start">
                    <li><i class="bi bi-check text-success"></i> Create new orders quickly</li>
                    <li><i class="bi bi-check text-success"></i> Track order status in real-time</li>
                    <li><i class="bi bi-check text-success"></i> Add multiple items to orders</li>
                    <li><i class="bi bi-check text-success"></i> View complete order history</li>
                </ul>
            </div>
        </div>
    </div>
    
    <!-- Table Management -->
    <div class="col-lg-4 col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <div class="stat-card yellow mx-auto mb-3" style="width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-grid-3x3" style="font-size: 2rem;"></i>
                </div>
                <h4>Table Management</h4>
                <p class="text-muted">
                    Efficiently manage your restaurant tables, track availability, 
                    and optimize seating arrangements for maximum capacity.
                </p>
                <ul class="list-unstyled text-start">
                    <li><i class="bi bi-check text-success"></i> Visual table layout</li>
                    <li><i class="bi bi-check text-success"></i> Real-time availability tracking</li>
                    <li><i class="bi bi-check text-success"></i> Table capacity management</li>
                    <li><i class="bi bi-check text-success"></i> Quick status toggle</li>
                </ul>
            </div>
        </div>
    </div>
    
    <!-- Menu Management -->
    <div class="col-lg-4 col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <div class="stat-card red mx-auto mb-3" style="width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-menu-button-wide" style="font-size: 2rem;"></i>
                </div>
                <h4>Menu Management</h4>
                <p class="text-muted">
                    Complete control over your menu items and categories. 
                    Update prices, descriptions, and availability instantly.
                </p>
                <ul class="list-unstyled text-start">
                    <li><i class="bi bi-check text-success"></i> Add/edit menu items</li>
                    <li><i class="bi bi-check text-success"></i> Organize by categories</li>
                    <li><i class="bi bi-check text-success"></i> Toggle item availability</li>
                    <li><i class="bi bi-check text-success"></i> Set prices and descriptions</li>
                </ul>
            </div>
        </div>
    </div>
    
    <!-- Employee Management -->
    <div class="col-lg-4 col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <div class="stat-card dark mx-auto mb-3" style="width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-people" style="font-size: 2rem;"></i>
                </div>
                <h4>Employee Management</h4>
                <p class="text-muted">
                    Manage your team with role-based access control. 
                    Track performance and assign appropriate permissions.
                </p>
                <ul class="list-unstyled text-start">
                    <li><i class="bi bi-check text-success"></i> Add/edit employee accounts</li>
                    <li><i class="bi bi-check text-success"></i> Role-based permissions</li>
                    <li><i class="bi bi-check text-success"></i> Track employee activity</li>
                    <li><i class="bi bi-check text-success"></i> Activate/deactivate accounts</li>
                </ul>
            </div>
        </div>
    </div>
    
    <!-- Payment Processing -->
    <div class="col-lg-4 col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <div class="stat-card blue mx-auto mb-3" style="width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-credit-card" style="font-size: 2rem;"></i>
                </div>
                <h4>Payment Processing</h4>
                <p class="text-muted">
                    Accept cash and card payments with automatic change calculation. 
                    Generate receipts and track all transactions.
                </p>
                <ul class="list-unstyled text-start">
                    <li><i class="bi bi-check text-success"></i> Cash & card payments</li>
                    <li><i class="bi bi-check text-success"></i> Automatic calculations</li>
                    <li><i class="bi bi-check text-success"></i> Receipt generation</li>
                    <li><i class="bi bi-check text-success"></i> Transaction history</li>
                </ul>
            </div>
        </div>
    </div>
    
    <!-- Reports & Analytics -->
    <div class="col-lg-4 col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <div class="stat-card yellow mx-auto mb-3" style="width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-graph-up" style="font-size: 2rem;"></i>
                </div>
                <h4>Reports & Analytics</h4>
                <p class="text-muted">
                    Comprehensive daily and monthly reports. Track revenue, 
                    top-selling items, and employee performance.
                </p>
                <ul class="list-unstyled text-start">
                    <li><i class="bi bi-check text-success"></i> Daily sales reports</li>
                    <li><i class="bi bi-check text-success"></i> Monthly summaries</li>
                    <li><i class="bi bi-check text-success"></i> Top-selling items</li>
                    <li><i class="bi bi-check text-success"></i> Employee performance</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Contact CTA -->
