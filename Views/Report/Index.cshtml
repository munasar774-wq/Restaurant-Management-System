@{
    ViewData["Title"] = "Reports";
}

<div class="page-header">
    <h1><i class="bi bi-graph-up"></i> Reports</h1>
</div>

<div class="row">
    <div class="col-md-6 mb-4">
        <a href="@Url.Action("Daily")" class="text-decoration-none">
            <div class="report-card">
                <i class="bi bi-calendar-day"></i>
                <h4>Daily Report</h4>
                <p>View today's sales, orders, and top items</p>
            </div>
        </a>
    </div>
    <div class="col-md-6 mb-4">
        <a href="@Url.Action("Monthly")" class="text-decoration-none">
            <div class="report-card">
                <i class="bi bi-calendar-month"></i>
                <h4>Monthly Report</h4>
                <p>View monthly revenue and performance metrics</p>
            </div>
        </a>
    </div>
</div>
