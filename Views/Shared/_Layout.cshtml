<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nexora Restaurant</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <!-- Main wrapper for authenticated users -->
        <div class="wrapper">
            <!-- Sidebar -->
            <nav id="sidebar" class="sidebar">
                <div class="sidebar-header">
                    <div class="d-flex align-items-center">
                        <img src="~/images/logo.jpg" alt="Nexora Logo" class="rounded-circle me-2" style="width: 40px; height: 40px; object-fit: cover;">
                        <h4 class="mb-0 text-white">Nexora</h4>
                    </div>
                </div>
                
                <ul class="list-unstyled components">
                    <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                        <a href="@Url.Action("Index", "Dashboard")">
                            <i class="bi bi-speedometer2"></i> Dashboard / Xog-Kooban
                        </a>
                    </li>
                    
                    <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Kitchen" ? "active" : "")">
                        <a href="@Url.Action("Index", "Kitchen")">
                            <i class="bi bi-fire"></i> Kitchen / Jikada
                        </a>
                    </li>

                    <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")">
                        <a href="@Url.Action("Index", "Order")">
                            <i class="bi bi-receipt"></i> Orders / Dalabaadka
                        </a>
                    </li>
                    
                    <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Table" ? "active" : "")">
                        <a href="@Url.Action("Index", "Table")">
                            <i class="bi bi-grid-3x3"></i> Tables / Miisaska
                        </a>
                    </li>

                    <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Reservation" ? "active" : "")">
                        <a href="@Url.Action("Index", "Reservation")">
                            <i class="bi bi-calendar-check"></i> Reservations / Boos-Qabsiga
                        </a>
                    </li>
                    
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="menu-header">
                            <span>Administration / Maamulka</span>
                        </li>
                        
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Menu" ? "active" : "")">
                            <a href="@Url.Action("Index", "Menu")">
                                <i class="bi bi-menu-button-wide"></i> Menu / Cuntada
                            </a>
                        </li>
                        
                        <li class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Categories" ? "active" : "")">
                            <a href="@Url.Action("Categories", "Menu")">
                                <i class="bi bi-tags"></i> Categories / Qaybaha
                            </a>
                        </li>
                        
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Employee" ? "active" : "")">
                            <a href="@Url.Action("Index", "Employee")">
                                <i class="bi bi-people"></i> Employees / Shaqaalaha
                            </a>
                        </li>
                        
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Inventory" ? "active" : "")">
                            <a href="@Url.Action("Index", "Inventory")">
                                <i class="bi bi-box-seam"></i> Inventory / Bakhaarka
                            </a>
                        </li>

                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Recipe" ? "active" : "")">
                            <a href="@Url.Action("Index", "Recipe")">
                                <i class="bi bi-journal-album"></i> Recipes / Cunto-Karis
                            </a>
                        </li>

                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" ? "active" : "")">
                            <a href="@Url.Action("Index", "Report")">
                                <i class="bi bi-graph-up"></i> Reports / Warbixino
                            </a>
                        </li>
                    }
                </ul>
                
                <div class="sidebar-footer d-none">
                    <!-- Footer moved to header -->
                </div>
            </nav>

            <!-- Page Content -->
            <div id="content">
                <!-- Top Navbar -->
                <nav class="navbar navbar-expand-lg top-navbar">
                    <div class="container-fluid">
                        <button type="button" id="sidebarCollapse" class="btn btn-primary">
                            <i class="bi bi-list"></i>
                        </button>

                        <!-- Search Bar -->
                        <div class="header-search-container d-none d-md-block">
                            <i class="bi bi-search header-search-icon"></i>
                            <input type="text" class="header-search-input" placeholder="Search / Baar...">
                        </div>
                        
                        <div class="ms-auto d-flex align-items-center gap-3">
                            <!-- User Type Badge -->
                            <span class="badge bg-white text-primary rounded-pill px-3 py-2 d-none d-sm-inline-block">
                                @(User.IsInRole("Admin") ? "Admin / Maamule" : "Employee / Shaqaale")
                            </span>

                            <!-- Profile Dropdown -->
                            <div class="dropdown header-profile-dropdown">
                                <button class="btn dropdown-toggle" type="button" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="header-profile-img">
                                        <i class="bi bi-person-fill"></i>
                                    </div>
                                    <span class="d-none d-sm-inline">@User.Identity?.Name</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 mt-2" aria-labelledby="profileDropdown">
                                    <li><a class="dropdown-item" href="#"><i class="bi bi-person me-2"></i> My Profile / Ciwaankayga</a></li>
                                    <li><a class="dropdown-item" href="#"><i class="bi bi-gear me-2"></i> Settings / Isku-Aadin</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-action="Logout" asp-controller="Account" method="post">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="bi bi-box-arrow-right me-2"></i> Logout / Ka-Bax
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </nav>

                <!-- Main Content -->
                <div class="main-content">
                    <!-- Alerts -->
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle"></i> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    
                    @RenderBody()
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Non-authenticated content -->
        @RenderBody()
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Toggle sidebar
        document.getElementById('sidebarCollapse')?.addEventListener('click', function() {
            document.getElementById('sidebar').classList.toggle('active');
            document.getElementById('content').classList.toggle('active');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
