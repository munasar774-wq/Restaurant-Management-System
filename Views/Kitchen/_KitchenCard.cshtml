@model RestaurantManagement.Models.Order
@using RestaurantManagement.Models

<div class="kitchen-card @(Model.Status == OrderStatus.Preparing ? "preparing" : "")">
    @if (Model.Status == OrderStatus.Preparing)
    {
        <div class="cooking-animation text-primary">
            <div class="spinner-border spinner-border-sm" role="status">
                <span class="visually-hidden">Cooking...</span>
            </div>
        </div>
    }
    <div class="order-header">
        <span class="fw-bold">Order #@Model.Id</span>
        <span class="badge bg-secondary">Table @Model.Table?.TableNumber</span>
    </div>
    <div class="small text-muted mb-2">
        <i class="bi bi-clock"></i> @Model.OrderDate.ToString("HH:mm")
    </div>
    
    <ul class="order-items">
        @foreach (var item in Model.OrderItems)
        {
            <li>
                <span>@item.MenuItem?.Name</span>
                <span class="badge bg-light text-dark border">x @item.Quantity</span>
            </li>
        }
    </ul>

    <div class="d-grid gap-2">
        @if (Model.Status == OrderStatus.Pending)
        {
            <button onclick="updateStatus(@Model.Id, 'Preparing')" class="btn btn-primary btn-sm">
                <i class="bi bi-fire"></i> Start Cooking
            </button>
        }
        else if (Model.Status == OrderStatus.Preparing)
        {
            <button onclick="updateStatus(@Model.Id, 'Ready')" class="btn btn-success btn-sm">
                <i class="bi bi-check-lg"></i> Mark as Ready
            </button>
        }
        else if (Model.Status == OrderStatus.Ready)
        {
            <button onclick="updateStatus(@Model.Id, 'Delivered')" class="btn btn-info btn-sm text-white">
                <i class="bi bi-bell"></i> Send to Waiter
            </button>
        }
    </div>
</div>
